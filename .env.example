# Required: Google Generative AI API key — used for the two-step AI pipeline.
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: override the Gemini model. Defaults to gemini-3.1-flash-lite-preview.
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Required: Tavily web search API key (external API #1).
# Free tier at https://tavily.com/
TAVILY_API_KEY=

# Required: NewsAPI.org key (external API #2).
# Free developer tier at https://newsapi.org/
NEWSAPI_KEY=

# Required: Resend API key for email delivery.
# Free tier at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: from-address for the enriched CSV email.
# Defaults to onboarding@resend.dev (Resend's shared sandbox sender,
# which only delivers to the address that owns the API key).
# For arbitrary recipients, verify a domain in Resend and set this
# to a from-address on that domain.
# RESEND_FROM=leads@yourdomain.com
